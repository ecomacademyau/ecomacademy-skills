{%- liquid
  assign block_settings = block.settings
  assign product = closest.product
  assign pitch = product.metafields.custom.pitch | default: block_settings.fallback_pitch
-%}

{%- if pitch != blank -%}
  <div
    class="eca-pitch spacing-style{% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}"
    style="
      --eca-pitch-font-size: {{ block_settings.font_size }};
      --eca-pitch-line-height: {{ block_settings.line_height }};
      {% render 'spacing-style', settings: block_settings %}
    "
    {{ block.shopify_attributes }}
  >
    {{ pitch }}
  </div>
{%- endif -%}

{% stylesheet %}
  .eca-pitch {
    font-family: var(--font-body--family);
    font-size: var(--eca-pitch-font-size, 1.0625rem);
    line-height: var(--eca-pitch-line-height, 1.5);
    color: var(--color-foreground);
    max-width: 60ch;
  }

  .eca-pitch p {
    margin: 0;
  }

  .eca-pitch p + p {
    margin-top: 0.5em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "ECA Pitch",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Reads from product metafield 'custom.pitch' (rich text or multi-line text). Use the fallback below when the metafield is empty."
    },
    {
      "type": "richtext",
      "id": "fallback_pitch",
      "label": "Fallback pitch",
      "default": "<p>A short, benefit-led sentence about what this product does for the customer.</p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Font size",
      "options": [
        { "value": "0.9375rem", "label": "Small (15px)" },
        { "value": "1rem", "label": "Default (16px)" },
        { "value": "1.0625rem", "label": "Medium (17px)" },
        { "value": "1.125rem", "label": "Large (18px)" },
        { "value": "1.25rem", "label": "Extra large (20px)" }
      ],
      "default": "1.0625rem"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "options": [
        { "value": "1.3", "label": "Tight" },
        { "value": "1.5", "label": "Normal" },
        { "value": "1.7", "label": "Loose" }
      ],
      "default": "1.5"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "Inherit color scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-block-end",   "label": "Bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-start","label": "Left", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding-inline-end",  "label": "Right", "min": 0, "max": 100, "step": 1, "unit": "px", "default": 0 }
  ],
  "presets": [
    { "name": "ECA Pitch" }
  ]
}
{% endschema %}
