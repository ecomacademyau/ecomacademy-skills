{%- liquid
  assign s = section.settings
-%}

<div
  class="eca-section eca-faq color-{{ s.color_scheme }}"
  style="
    --eca-section-pt: {{ s.padding-block-start }}px;
    --eca-section-pb: {{ s.padding-block-end }}px;
    --eca-faq-max: {{ s.max_width }}px;
  "
>
  <div class="eca-section__inner page-width">
    {%- if s.heading != blank -%}
      <header class="eca-section__header" style="text-align: {{ s.heading_alignment }};">
        {%- if s.eyebrow != blank -%}
          <p class="eca-section__eyebrow">{{ s.eyebrow }}</p>
        {%- endif -%}
        <h2 class="eca-section__heading">{{ s.heading }}</h2>
        {%- if s.subheading != blank -%}
          <div class="eca-section__subheading">{{ s.subheading }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="eca-faq__list">
      {%- for block in section.blocks -%}
        <details class="eca-faq__item" {% if block.settings.open_by_default %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="eca-faq__question">
            <span>{{ block.settings.question }}</span>
            <svg class="eca-faq__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6,9 12,15 18,9"/></svg>
          </summary>
          <div class="eca-faq__answer">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- comment -%} FAQPage structured data {%- endcomment -%}
{%- if section.blocks.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in section.blocks -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{% stylesheet %}
  .eca-faq {
    padding-block-start: var(--eca-section-pt, 0);
    padding-block-end: var(--eca-section-pb, 0);
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  .eca-faq__list {
    max-width: var(--eca-faq-max, 760px);
    margin: 0 auto;
  }

  .eca-faq__item {
    border-block-start: 1px solid var(--color-border);
  }

  .eca-faq__item:last-child {
    border-block-end: 1px solid var(--color-border);
  }

  .eca-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.25rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading--family, var(--font-body--family));
    font-size: 1rem;
    line-height: 1.4;
  }

  .eca-faq__question::-webkit-details-marker { display: none; }

  .eca-faq__icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .eca-faq__item[open] .eca-faq__icon {
    transform: rotate(180deg);
  }

  .eca-faq__answer {
    padding-block-end: 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.85;
  }

  .eca-faq__answer p { margin: 0 0 0.75em; }
  .eca-faq__answer p:last-child { margin-bottom: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "ECA FAQ",
  "tag": "section",
  "class": "section-eca-faq",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "max_width", "label": "Content width", "min": 480, "max": 1100, "step": 20, "unit": "px", "default": 760 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does shipping take?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Orders ship within 1 business day. US delivery is typically 3–5 days.</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "ECA FAQ",
      "category": "Product",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long does shipping take?", "open_by_default": true } },
        { "type": "faq", "settings": { "question": "What's your return policy?" } },
        { "type": "faq", "settings": { "question": "Is this safe for sensitive skin?" } },
        { "type": "faq", "settings": { "question": "How do I use it?" } }
      ]
    }
  ]
}
{% endschema %}
