{%- liquid
  assign s = section.settings
-%}

<div
  class="eca-section eca-value-props color-{{ s.color_scheme }}"
  style="
    --eca-section-pt: {{ s.padding-block-start }}px;
    --eca-section-pb: {{ s.padding-block-end }}px;
    --eca-vp-columns: {{ s.columns }};
    --eca-vp-gap: {{ s.gap }}px;
    --eca-vp-align: {{ s.alignment }};
  "
>
  <div class="eca-section__inner page-width">
    {%- if s.heading != blank -%}
      <header class="eca-section__header" style="text-align: {{ s.heading_alignment }};">
        {%- if s.eyebrow != blank -%}
          <p class="eca-section__eyebrow">{{ s.eyebrow }}</p>
        {%- endif -%}
        <h2 class="eca-section__heading">{{ s.heading }}</h2>
        {%- if s.subheading != blank -%}
          <div class="eca-section__subheading">{{ s.subheading }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="eca-value-props__grid">
      {%- for block in section.blocks -%}
        <div class="eca-value-props__item" {{ block.shopify_attributes }}>
          <div class="eca-value-props__icon-wrap">
            {%- if block.settings.custom_icon != blank -%}
              {{ block.settings.custom_icon | image_url: width: 96 | image_tag: loading: 'lazy', class: 'eca-value-props__custom-icon', alt: block.settings.heading }}
            {%- else -%}
              {%- render 'eca-trust-icon', icon: block.settings.icon -%}
            {%- endif -%}
          </div>
          {%- if block.settings.heading != blank -%}
            <h3 class="eca-value-props__heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <div class="eca-value-props__body">{{ block.settings.body }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .eca-section {
    padding-block-start: var(--eca-section-pt, 0);
    padding-block-end: var(--eca-section-pb, 0);
    background-color: var(--color-background);
    color: var(--color-foreground);
  }

  .eca-section__inner {
    margin-inline: auto;
    max-width: var(--page-width, 1400px);
    padding-inline: var(--page-margin, 1.5rem);
  }

  .eca-section__header {
    margin-bottom: 2rem;
  }

  .eca-section__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.7;
  }

  .eca-section__heading {
    margin: 0;
    font-family: var(--font-heading--family, var(--font-body--family));
    font-size: clamp(1.5rem, 2.4vw, 2.25rem);
    line-height: 1.2;
    color: var(--color-foreground);
  }

  .eca-section__subheading {
    max-width: 60ch;
    margin: 0.75rem auto 0;
    color: var(--color-foreground);
    opacity: 0.8;
  }

  .eca-value-props__grid {
    display: grid;
    grid-template-columns: repeat(var(--eca-vp-columns, 4), minmax(0, 1fr));
    gap: var(--eca-vp-gap, 24px);
  }

  .eca-value-props__item {
    text-align: var(--eca-vp-align, center);
    display: flex;
    flex-direction: column;
    align-items: var(--eca-vp-align, center);
  }

  .eca-value-props__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    margin-bottom: 1rem;
    border-radius: var(--style-border-radius, 8px);
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
  }

  .eca-value-props__icon-wrap svg {
    width: 28px;
    height: 28px;
    color: var(--color-foreground);
  }

  .eca-value-props__custom-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .eca-value-props__heading {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading--family, var(--font-body--family));
    font-size: 1.0625rem;
    line-height: 1.3;
  }

  .eca-value-props__body {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-foreground);
    opacity: 0.8;
  }

  .eca-value-props__body p { margin: 0; }

  @media (max-width: 989px) {
    .eca-value-props__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 549px) {
    .eca-value-props__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "ECA Value props",
  "tag": "section",
  "class": "section-eca-value-props",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why people love it" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built to do one thing — really well" },
    { "type": "richtext", "id": "subheading", "label": "Subheading" },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Grid" },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2, "max": 5, "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 8, "max": 64, "step": 4, "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Item alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    {
      "type": "prop",
      "name": "Value prop",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Check" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "heart", "label": "Heart" },
            { "value": "medal", "label": "Medal" },
            { "value": "hand", "label": "Hand" },
            { "value": "clock", "label": "Clock" },
            { "value": "truck", "label": "Truck" }
          ],
          "default": "check"
        },
        { "type": "image_picker", "id": "custom_icon", "label": "Custom icon (overrides above)" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Real benefit" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>One sentence that explains what the customer gets and why it matters.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ECA Value props",
      "category": "Product",
      "blocks": [
        { "type": "prop", "settings": { "icon": "check", "heading": "Backed by results" } },
        { "type": "prop", "settings": { "icon": "leaf", "heading": "Clean ingredients" } },
        { "type": "prop", "settings": { "icon": "shield", "heading": "30-day guarantee" } },
        { "type": "prop", "settings": { "icon": "heart", "heading": "Loved by 10,000+" } }
      ]
    }
  ]
}
{% endschema %}
