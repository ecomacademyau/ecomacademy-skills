{%- liquid
  assign s = section.settings
  assign product = closest.product | default: product
-%}

<div
  id="eca-reviews"
  class="eca-section eca-reviews color-{{ s.color_scheme }}"
  style="
    --eca-section-pt: {{ s.padding-block-start }}px;
    --eca-section-pb: {{ s.padding-block-end }}px;
  "
>
  <div class="eca-section__inner page-width">
    {%- if s.heading != blank -%}
      <header class="eca-section__header" style="text-align: {{ s.heading_alignment }};">
        {%- if s.eyebrow != blank -%}
          <p class="eca-section__eyebrow">{{ s.eyebrow }}</p>
        {%- endif -%}
        <h2 class="eca-section__heading">{{ s.heading }}</h2>
      </header>
    {%- endif -%}

    <div class="eca-reviews__embed">
      {%- case s.provider -%}
        {%- when 'judgeme' -%}
          <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}" data-product-title="{{ product.title | escape }}" data-product-handle="{{ product.handle }}"></div>
        {%- when 'loox' -%}
          <div id="looxReviews" data-product-id="{{ product.id }}"></div>
        {%- when 'stamped' -%}
          <div id="stamped-main-widget" data-product-id="{{ product.id }}" data-name="{{ product.title | escape }}" data-url="{{ shop.url | append: product.url }}"></div>
        {%- when 'yotpo' -%}
          <div class="yotpo yotpo-main-widget" data-product-id="{{ product.id }}" data-name="{{ product.title | escape }}" data-url="{{ shop.url | append: product.url }}" data-image-url="{{ product.featured_image | image_url: width: 600 }}"></div>
        {%- when 'okendo' -%}
          <div data-oke-widget data-oke-product-id="shopify-{{ product.id }}"></div>
        {%- when 'shopify' -%}
          <div class="shopify-product-reviews-badge" data-id="{{ product.id }}"></div>
          <div id="shopify-product-reviews" data-id="{{ product.id }}"></div>
        {%- when 'custom' -%}
          {{ s.custom_embed }}
        {%- else -%}
          <p class="eca-reviews__placeholder">Add your reviews app embed code in the section settings.</p>
      {%- endcase -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .eca-reviews {
    padding-block-start: var(--eca-section-pt, 0);
    padding-block-end: var(--eca-section-pb, 0);
    background-color: var(--color-background);
    color: var(--color-foreground);
    scroll-margin-block-start: 80px;
  }

  .eca-reviews__embed {
    min-height: 200px;
  }

  .eca-reviews__placeholder {
    text-align: center;
    padding: 3rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--style-border-radius, 8px);
    color: var(--color-foreground);
    opacity: 0.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "ECA Reviews",
  "tag": "section",
  "class": "section-eca-reviews",
  "settings": [
    {
      "type": "paragraph",
      "content": "Drops your reviews app widget onto the page. Pick your provider below — or use Custom to paste your own embed snippet."
    },
    {
      "type": "select",
      "id": "provider",
      "label": "Reviews app",
      "options": [
        { "value": "judgeme", "label": "Judge.me" },
        { "value": "loox", "label": "Loox" },
        { "value": "stamped", "label": "Stamped.io" },
        { "value": "yotpo", "label": "Yotpo" },
        { "value": "okendo", "label": "Okendo" },
        { "value": "shopify", "label": "Shopify Product Reviews" },
        { "value": "custom", "label": "Custom embed" }
      ],
      "default": "judgeme"
    },
    {
      "type": "html",
      "id": "custom_embed",
      "label": "Custom embed code",
      "visible_if": "{{ section.settings.provider == 'custom' }}"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What customers are saying" },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [
    { "name": "ECA Reviews", "category": "Product" }
  ]
}
{% endschema %}
