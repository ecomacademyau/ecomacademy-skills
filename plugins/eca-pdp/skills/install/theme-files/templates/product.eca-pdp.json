{
  "name": "ECA PDP",
  "sections": {
    "main": {
      "type": "product-information",
      "blocks": {
        "media-gallery": {
          "type": "_product-media-gallery",
          "static": true,
          "settings": {
            "media_presentation": "stacked",
            "media_columns": "two",
            "image_gap": 4,
            "large_first_image": true,
            "icons_style": "arrow",
            "slideshow_controls_style": "counter",
            "slideshow_mobile_controls_style": "dots",
            "thumbnail_position": "below",
            "thumbnail_width": 56,
            "aspect_ratio": "adapt",
            "constrain_to_viewport": true,
            "media_fit": "contain",
            "media_radius": 8,
            "extend_media": false,
            "zoom": true,
            "video_loop": false,
            "hide_variants": true,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "product-details": {
          "type": "_product-details",
          "static": true,
          "settings": {
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "details_position": "flex-start",
            "gap": 16,
            "sticky_details_desktop": true,
            "inherit_color_scheme": true,
            "color_scheme": "scheme-1",
            "background_media": "none",
            "video_position": "cover",
            "background_image_position": "cover",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 24,
            "padding-block-end": 24,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "title": {
              "type": "text",
              "name": "Title",
              "settings": {
                "text": "<h1>{{ closest.product.title }}</h1>",
                "width": "100%",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h2",
                "font_size": "",
                "line_height": "tight",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "balance",
                "color": "var(--color-foreground)",
                "background": false,
                "background_color": "#00000026",
                "corner_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "stars": {
              "type": "review",
              "settings": {
                "padding-block-start": 4,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "pitch": {
              "type": "eca-pitch",
              "settings": {
                "font_size": "1.0625rem",
                "line_height": "1.5",
                "inherit_color_scheme": true,
                "padding-block-start": 8,
                "padding-block-end": 8,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "show_installments": true,
                "show_tax_info": false,
                "type_preset": "h5",
                "width": "100%",
                "alignment": "left",
                "font_size": "1.375rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "color": "var(--color-foreground)",
                "padding-block-start": 4,
                "padding-block-end": 8,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "divider-1": {
              "type": "_divider",
              "settings": {
                "thickness": 1,
                "corner_radius": "square",
                "width_percent": 100,
                "padding-block-start": 8,
                "padding-block-end": 8
              },
              "blocks": {}
            },
            "variant-picker": {
              "type": "variant-picker",
              "settings": {
                "variant_style": "buttons",
                "show_swatches": true,
                "alignment": "left",
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "sizing-guide": {
              "type": "eca-sizing-guide-link",
              "settings": {
                "link_text": "Sizing guide",
                "heading": "Sizing guide",
                "padding-block-start": 0,
                "padding-block-end": 8,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "buy-buttons": {
              "type": "buy-buttons",
              "settings": {
                "stacking": false,
                "show_pickup_availability": false,
                "gift_card_form": true,
                "padding-block-start": 8,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {
                "quantity": {
                  "type": "quantity",
                  "static": true,
                  "settings": {},
                  "blocks": {}
                },
                "add-to-cart": {
                  "type": "add-to-cart",
                  "static": true,
                  "settings": { "style_class": "button" },
                  "blocks": {}
                },
                "accelerated-checkout": {
                  "type": "accelerated-checkout",
                  "static": true,
                  "settings": {},
                  "blocks": {}
                }
              },
              "block_order": []
            },
            "trust-row": {
              "type": "eca-trust-row",
              "settings": {
                "show_shipping": true,
                "shipping_icon": "truck",
                "shipping_label": "Free shipping",
                "shipping_subtext": "Orders over $50",
                "show_guarantee": true,
                "guarantee_icon": "shield",
                "guarantee_label": "30-day returns",
                "guarantee_subtext": "No questions asked",
                "show_secure": false,
                "secure_icon": "lock",
                "secure_label": "Secure checkout",
                "secure_subtext": "SSL encrypted",
                "gap": 16,
                "icon_size": 22,
                "inherit_color_scheme": true,
                "padding-block-start": 16,
                "padding-block-end": 8,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "accordion": {
              "type": "accordion",
              "settings": {
                "icon": "plus",
                "dividers": true,
                "type_preset": "h6",
                "inherit_color_scheme": true,
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0,
                "padding-block-start": 8,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {
                "row-description": {
                  "type": "_accordion-row",
                  "settings": {
                    "open_by_default": false,
                    "heading": "Description"
                  },
                  "blocks": {
                    "description-text": {
                      "type": "product-description",
                      "settings": {
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "padding-block-start": 0,
                        "padding-block-end": 0,
                        "padding-inline-start": 0,
                        "padding-inline-end": 0
                      },
                      "blocks": {}
                    }
                  },
                  "block_order": ["description-text"]
                },
                "row-shipping": {
                  "type": "_accordion-row",
                  "settings": {
                    "open_by_default": false,
                    "heading": "Shipping"
                  },
                  "blocks": {
                    "shipping-text": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Orders ship within 1 business day. Free shipping on orders over $50. Tracking is emailed as soon as the label is generated.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "padding-block-start": 0,
                        "padding-block-end": 0,
                        "padding-inline-start": 0,
                        "padding-inline-end": 0
                      },
                      "blocks": {}
                    }
                  },
                  "block_order": ["shipping-text"]
                },
                "row-returns": {
                  "type": "_accordion-row",
                  "settings": {
                    "open_by_default": false,
                    "heading": "Returns"
                  },
                  "blocks": {
                    "returns-text": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Not the right fit? Return within 30 days for a full refund. No restocking fees, no questions asked.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "padding-block-start": 0,
                        "padding-block-end": 0,
                        "padding-inline-start": 0,
                        "padding-inline-end": 0
                      },
                      "blocks": {}
                    }
                  },
                  "block_order": ["returns-text"]
                },
                "row-extra": {
                  "type": "_accordion-row",
                  "settings": {
                    "open_by_default": false,
                    "heading": "How to care for it"
                  },
                  "blocks": {
                    "extra-text": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Add a fourth accordion row for ingredients, materials, care instructions, certifications — whatever your customers ask about most.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "padding-block-start": 0,
                        "padding-block-end": 0,
                        "padding-inline-start": 0,
                        "padding-inline-end": 0
                      },
                      "blocks": {}
                    }
                  },
                  "block_order": ["extra-text"]
                }
              },
              "block_order": ["row-description", "row-shipping", "row-returns", "row-extra"]
            }
          },
          "block_order": [
            "title",
            "stars",
            "pitch",
            "price",
            "divider-1",
            "variant-picker",
            "sizing-guide",
            "buy-buttons",
            "trust-row",
            "accordion"
          ]
        }
      },
      "settings": {
        "content_width": "page-width",
        "desktop_media_position": "left",
        "equal_columns": false,
        "limit_details_width": true,
        "gap": 48,
        "color_scheme": "",
        "padding-block-start": 24,
        "padding-block-end": 24
      }
    },

    "eca_value_props": {
      "type": "eca-value-props",
      "blocks": {
        "p1": { "type": "prop", "settings": { "icon": "check", "heading": "Backed by results", "body": "<p>One short sentence about a measurable benefit. Numbers convert.</p>" } },
        "p2": { "type": "prop", "settings": { "icon": "leaf", "heading": "Clean ingredients", "body": "<p>Address the #1 objection your category faces in one line.</p>" } },
        "p3": { "type": "prop", "settings": { "icon": "shield", "heading": "30-day guarantee", "body": "<p>Risk reversal. Tell them exactly what happens if they don't love it.</p>" } },
        "p4": { "type": "prop", "settings": { "icon": "heart", "heading": "Loved by 10,000+", "body": "<p>Social proof in plain numbers. Show, don't tell.</p>" } }
      },
      "block_order": ["p1", "p2", "p3", "p4"],
      "settings": {
        "eyebrow": "Why people choose this",
        "heading": "Built to do one thing — really well",
        "subheading": "",
        "heading_alignment": "center",
        "columns": 4,
        "gap": 24,
        "alignment": "center",
        "color_scheme": "scheme-1",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },

    "eca_how_to_use": {
      "type": "eca-how-to-use",
      "blocks": {
        "s1": { "type": "step", "settings": { "heading": "Open it up", "body": "<p>One sentence about the first step. Keep it short, sensory, and concrete.</p>" } },
        "s2": { "type": "step", "settings": { "heading": "Apply or use it", "body": "<p>One sentence about the second step. Show, don't tell.</p>" } },
        "s3": { "type": "step", "settings": { "heading": "Enjoy the results", "body": "<p>One sentence about what they'll see, feel, or experience.</p>" } }
      },
      "block_order": ["s1", "s2", "s3"],
      "settings": {
        "eyebrow": "How it works",
        "heading": "Three simple steps",
        "heading_alignment": "center",
        "columns": 3,
        "gap": 32,
        "color_scheme": "scheme-2",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },

    "eca_ugc": {
      "type": "eca-ugc-gallery",
      "blocks": {
        "u1": { "type": "media", "settings": { "handle": "@customer1" } },
        "u2": { "type": "media", "settings": { "handle": "@customer2" } },
        "u3": { "type": "media", "settings": { "handle": "@customer3" } },
        "u4": { "type": "media", "settings": { "handle": "@customer4" } }
      },
      "block_order": ["u1", "u2", "u3", "u4"],
      "settings": {
        "eyebrow": "Real people, real results",
        "heading": "From our community",
        "heading_alignment": "center",
        "columns": 4,
        "gap": 12,
        "aspect_ratio": "1 / 1",
        "color_scheme": "scheme-1",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },

    "eca_faq": {
      "type": "eca-faq",
      "blocks": {
        "q1": { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "<p>Orders ship within 1 business day. US delivery is typically 3–5 days.</p>", "open_by_default": true } },
        "q2": { "type": "faq", "settings": { "question": "What's your return policy?", "answer": "<p>30 days, no questions asked. Email us and we'll send a return label.</p>", "open_by_default": false } },
        "q3": { "type": "faq", "settings": { "question": "Is this safe for sensitive skin?", "answer": "<p>Address the top safety / suitability question your customers actually ask.</p>", "open_by_default": false } },
        "q4": { "type": "faq", "settings": { "question": "How do I use it?", "answer": "<p>Link to the 'How it works' section above or summarize in two sentences.</p>", "open_by_default": false } }
      },
      "block_order": ["q1", "q2", "q3", "q4"],
      "settings": {
        "heading": "Frequently asked questions",
        "heading_alignment": "center",
        "max_width": 760,
        "color_scheme": "scheme-2",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },

    "eca_reviews": {
      "type": "eca-reviews-embed",
      "settings": {
        "provider": "judgeme",
        "heading": "What customers are saying",
        "heading_alignment": "center",
        "color_scheme": "scheme-1",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },

    "eca_founder": {
      "type": "eca-founder",
      "settings": {
        "eyebrow": "About the founder",
        "heading": "Why I built this",
        "body": "<p>Share the origin story in 2–4 short paragraphs. Why does this product exist? What was wrong with the alternatives? Speak directly to the customer.</p>",
        "name": "Your name",
        "title": "Founder & CEO",
        "layout": "media-left",
        "color_scheme": "scheme-2",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    },

    "product_recommendations": {
      "type": "product-recommendations",
      "blocks": {
        "header": {
          "type": "text",
          "settings": {
            "text": "<h3>You may also like</h3>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "left",
            "type_preset": "h4",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "product_card_gap": 8,
            "inherit_color_scheme": true,
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 8,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "card-gallery": {
              "type": "_product-card-gallery",
              "settings": {
                "image_ratio": "adapt",
                "border": "none",
                "border_width": 1,
                "border_opacity": 100,
                "border_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "card-title": {
              "type": "product-title",
              "settings": {
                "width": "100%",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "rte",
                "color": "var(--color-foreground)",
                "padding-block-start": 4,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            },
            "card-price": {
              "type": "price",
              "settings": {
                "show_sale_price_first": true,
                "show_installments": false,
                "show_tax_info": false,
                "type_preset": "h6",
                "width": "100%",
                "alignment": "left",
                "color": "var(--color-foreground)",
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
            }
          },
          "block_order": ["card-gallery", "card-title", "card-price"]
        }
      },
      "block_order": ["header"],
      "settings": {
        "product": "{{ closest.product }}",
        "recommendation_type": "related",
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "max_products": 4,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 12,
        "rows_gap": 24,
        "icons_style": "arrow",
        "icons_shape": "none",
        "section_width": "page-width",
        "gap": 28,
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  },
  "order": [
    "main",
    "eca_value_props",
    "eca_how_to_use",
    "eca_ugc",
    "eca_faq",
    "eca_reviews",
    "eca_founder",
    "product_recommendations"
  ]
}
